# Generate a secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars

# Comma-separated list of hostnames/IPs Django will accept requests for.
ALLOWED_HOSTS=localhost,127.0.0.1,practice.smallcaps.internal

# Full base URLs Django accepts CSRF tokens from.
CSRF_TRUSTED_ORIGINS=http://practice.smallcaps.internal

# Hostname routed by nginx-proxy to the nginx container.
# nginx-proxy reads this from the nginx container's environment (set in docker-compose.yml).
# You don't need to change it here unless you rename the host.
VIRTUAL_HOST=practice.smallcaps.internal

# For AI passage analysis (optional — manual tagging works without this)
# ANTHROPIC_API_KEY=sk-ant-...

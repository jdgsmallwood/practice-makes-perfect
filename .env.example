# Generate a secret key with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars

# Comma-separated list of hostnames/IPs the app will accept requests for.
# Add your Pi's local IP, hostname, and/or domain.
ALLOWED_HOSTS=localhost,127.0.0.1,raspberrypi.local,192.168.1.100

# Full base URLs that Django will accept CSRF tokens from.
# Must match every URL you use to access the app.
CSRF_TRUSTED_ORIGINS=http://raspberrypi.local,http://192.168.1.100

# For AI passage analysis (optional — manual tagging works without this)
# Get a key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
